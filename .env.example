# =============================================================================
# Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All backend config lives in the root .env.example.
# =============================================================================

# API base URL — point this at whichever backend you're running:
#   FastAPI (Python) → http://localhost:8000/api/v1
#   Bun + Hono (TS)  → http://localhost:3000/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# App display name
VITE_APP_NAME="Your App Name"
VITE_APP_DESCRIPTION="A description of your app for SEO and social sharing."

# Optional: OpenAPI spec URL for SDK generation (bun run gen:api)
#   FastAPI  → http://localhost:8000/openapi.json
#   Bun+Hono → http://localhost:3000/openapi.json
# OPENAPI_FILE=http://localhost:8000/openapi.json

# Cloudflare Turnstile (optional)
# Leave empty to disable Turnstile in local/dev.
# Get your site key from Cloudflare Turnstile dashboard.
VITE_TURNSTILE_SITE_KEY=
